# ─── Server ──────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── PostgreSQL ──────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/dyslearn

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=15m
REFRESH_SECRET=another_long_random_string_for_refresh_tokens
REFRESH_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── ML Microservice ─────────────────────────────────────────
ML_SERVICE_URL=http://localhost:8000

# ─── Email (Nodemailer / Resend SMTP) ─────────────────────────
EMAIL_FROM=noreply@dyslearn.com
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=your_resend_api_key
